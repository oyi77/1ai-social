# 1ai-social Configuration Example
# Copy this to .env and fill in your actual values

# === Required API Keys ===

# PostBridge - Social media posting
POSTBRIDGE_API_KEY=your_postbridge_api_key_here

# NVIDIA NIM - AI video generation
NVIDIA_API_KEY=your_nvidia_api_key_here

# BytePlus - Video generation
BYTEPLUS_API_KEY=your_byteplus_api_key_here

# Groq - AI inference for hook generation
GROQ_API_KEY=your_groq_api_key_here

# === Database ===

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/1ai_social

# === Optional - Platform Defaults ===

# Default platforms to post to
DEFAULT_PLATFORMS=tiktok,instagram

# Default content type
DEFAULT_CONTENT_TYPE=video

# === Optional - Rate Limits ===

# Max posts per day
MAX_POSTS_PER_DAY=50

# Rate limit delays (seconds)
RATE_LIMIT_DELAY=60

# === Optional - Scheduler ===

# Enable background scheduler
SCHEDULER_ENABLED=false

# Cron schedule for automated posts
SCHEDULER_CRON=0 9 * * *

# === Optional - Analytics ===

# Analytics retention days
ANALYTICS_RETENTION_DAYS=90

# Confidence decay factor
CONFIDENCE_DECAY=0.95

# === Optional - MCP Server ===

# MCP server host
MCP_HOST=0.0.0.0

# MCP server port
MCP_PORT=8000
